"is_public","created_at","updated_at") VALUES (NULL,
'1',
'I just delete the node_modules folder',
'
<p>due to the file size matter and the fact that we have nothing to do with
node_modules folder and it''s content so I just delete and set the .gitignore
for nodee_modules to just ignore it from looking and sync with the project
code base on github now for new git pull please go to the root of your project
foder then run "npm install" the node_modules folder will be back for you to
start develop with any of the new vue components</p>

',
