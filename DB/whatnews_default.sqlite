INSERT INTO `whatnews` (`id`,`user_id`,`whatnews_title`,`whatnews_body`,
`is_public`,`created_at`,`updated_at`) VALUES (NULL,
'1',                            
'
ทดลองใช้ อุบุนตู 21.04 ในโปรแกรม virtualbox กันเถอะ

',                             
'
<div class="container">
    <p class="mb-4">
        ปรกติผมจะทำวิดิโอแล้วโพสใน <a 
        href="https://www.youtube.com/channel/UCnApixzVAeTN0xLXuERn89g" 
        class="btn btn-outline-primary" target="_blank">
        youtube</a> ของผมซึ่งก็เหมือนๆ กับเวปไซต์นั่นแหละ คือ "ไม่มีคนดู" ฮ่าๆ อ้ะ ทำเองก็ดูเอง 
        นักเลงพอ สำหรับใครก็ตามที่สนใจจะใช้งาน Ubuntu 21.04 อยากจะทดลองดูในโปรแกรม 
        Virtualbox ลองดูวิดิโอนี้นะครับ 
    </p>

    <div class="video-container pt-2">
        <iframe src="https://archive.org/embed/ubuntu-21-04_like_small-kid" 
        width="640" height="480" frameborder="0" webkitallowfullscreen="true" 
        mozallowfullscreen="true" allowfullscreen></iframe>
    </div>

</div>

',                                          
'1',                        
'2021-05-19 17:45:05',                
'2021-05-19 17:45:10'                 
);                                          








/* Conf Vue3 by Even You 19 May 2021*/
INSERT INTO `whatnews` (`id`,`user_id`,`whatnews_title`,`whatnews_body`,
`is_public`,`created_at`,`updated_at`) VALUES (NULL,
'1',                            
'
Is there any one learn vue on 2021

',                             
'
<div class="row">
    <div class="col-lg-12">
        <p class="pt-2 mb-2">
        to learn "laravel" and "vue" is quite easy to picking up even you came 
        from another framework like codeigniter as myself do from last year 
        Oct 2020 up until now (19 May 2021) I am with laravel 8 and still using 
        vue 2 by the way but this will be move to vue 3 soon.
        </p>
        <div class="video-container">
            <iframe width="560" height="315" 
            src="https://www.youtube.com/embed/WLpLYhnGqPA" 
            title="Design Principles of Vue 3.0 by Evan You" 
            frameborder="0" allow="accelerometer; autoplay; 
            clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
            allowfullscreen></iframe>
        </div>
        <p class="pt-2 mb-2 text-center">
            Design Principles of Vue 3.0 by Evan You
        </p>
        <p class="pt-2 mb-2">
            but up until now I no nothing about Vue3 still! 💔
        </p>
    </div>
</div>


',                                          
'1',                        
'2021-05-19 12:12:05',                
'2021-05-19 12:12:10'                 
);                                          




/* รถไฟความเร็วสูงของจีน 19 May 2021*/
INSERT INTO `whatnews` (`id`,`user_id`,`whatnews_title`,`whatnews_body`,
`is_public`,`created_at`,`updated_at`) VALUES (NULL,
'1',                            
'จีนเค้ามีรถไฟความเร็วสูง(จริง ๆ) แล้วนะ รู้ยัง',                             
'

<div class="row">
    <div class="container">
        <h2 class="text-center">
            เห็นข่าวแบบนี้แล้วมันชื่นหัวจิต
        </h2>
        <p class="pt-2 mb-2">
        จริงๆ จีนเค้ามีรถไฟความเร็วสูงใช้กันมาพักใหญ่ๆ แล้วล่ะ จะว่าได้เหรอประเทศใหญ่ขนาดนั้น 
        แถมคนเป็นพันล้าน แต่ถึงยังงั้นก็ยังอดอิจฉาไม่ได้ แม๊....มึงจะล้ำไปไหนเมื่อไหร่จะมาบ้านกู?

        </p>
        <div class="video-container">
<iframe width="560" height="315" src="https://www.youtube.com/embed/-UjtYq3wcco" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        </div>
        <p class="pt-2 mb-4 text-center">
            มาเที่ยวเมืองไทยบ้างเถิด เทคโนโลยีจ๋า 
        </p>
    </div>
</div>

',                                          
'1',                        
'2021-05-19 08:35:05',                
'2021-05-19 08:35:10'                 
);                                          




/* หมอพร้อม พร้อมสิ้นเดือน*/
INSERT INTO `whatnews` (`id`,`user_id`,`whatnews_title`,`whatnews_body`,
`is_public`,`created_at`,`updated_at`) VALUES (NULL,
'1',                            
'หมอพร้อม เค้าเปิดให้ประชาชนทั่วไปลงทะเบียนตั้งแต่สิ้นเดือน พฤษภาคม ปี 2564 เว้ย',                             
'
<div class="row">
    <div class="col-lg-12">
        <p class="mb">
            เมื่อวานนี้(17-05-2564) ก็โง่ไปด่าโปรแกรมเมอร์ หมอพร้อม ซะเสียหายเลยทั้งที่จริงๆ 
            ตัวเอง(ผมเองนี่แหละ)ที่โง่ไม่ดูข่าว วันนี้(18-05-2564) ไปเปิดดูถึงรู้ อ้อ! อย่างนี้นี่เอง 
            ไอ้เวรเสือกไม่อ่านข่าวเอาแต่ไปโทษคนอื่น ไม่รู้ว่าใครเป็นอย่างผมบ้าง อะไรๆ ก็โทษคนอื่น
            ไว้ก่อน แม๊.....อย่างนี้เค้าเรียก นิสัยเสีย

        </p>
        <a href="https://www.bangkokbiznews.com/news/detail/938260" 
        target="_blank">
            <img class="responsive" 
            src="https://i.ibb.co/6gKPnqG/2021-05-18-vacine-normal.png" 
            alt="หมอจะพร้อมตอนสิ้นเดือนโน่น">
        </a>
        <p class="pt-4 mb-4">
            <span class="alert alert-warning">
                ประชาชนทั่วไป จองคิว "ฉีดวัคซีน" ผ่านหมอพร้อมได้เมื่อไร
            </span>
        </p>
        <ul class="list-group">
            <li class="list-group-item">
                <b-icon icon="book-half"></b-icon>
                ประชาชนทั่วไปที่มีอายุ 18-59 ปี จองคิวผ่านหมอพร้อมได้วันที่ 
                31 พ.ค. 64 เป็นต้นไป
            </li>
        </ul>
        <p class="pt-4 mb-4">
            เออ......กูผิดเอง!
        </p>

    </div>
</div>



',                                          
'1',                        
'2021-05-18 11:39:05',                
'2021-05-18 11:42:01'                 
);                                          




/* หมอยังไม่พร้อม*/
INSERT INTO `whatnews` (`id`,`user_id`,`whatnews_title`,`whatnews_body`,
`is_public`,`created_at`,`updated_at`) VALUES (NULL,
'1',                            
'ลองลงทะเบียนฉีดวัคซีนโควิดวันที่ 17-05-2564 กับ App หมอพร้อม',                             
'
<div class="row">
    <div class="col-lg-12">
        <p class="pt-4 mb-2">
            วันนี้ (17-05-2564) ทดลองลงทะเบียนฉีดวัคซีนผ่าน app หมอพร้อมในมือถือ 
            วีโว่ราคา 5 พันบาท ได้ความว่าไม่สามารถลงทะเบียนขอรับวัคซีนได้ 
            แอพมันเด้งว่าไม่พบวันว่าง กดไปจนถึงปีหน้าแล้วก็ยังไม่พบวันว่าง 
            ไม่รู้ว่ามันจะรอแล้วค่อยหาเจอตอนที่เค้าหายติดโควิดกันหมดทั้งโลกหรือเปล่า 
            ผมไม่เข้าใจอยู่เรื่องเดียว ทำไมวะ ไอ้เวปไซต์ หรือระบบต่างๆ ของทางราชการ
            ตั้งแต่ของประกันสังคมมา จนถึงหมอพร้อม มันถึงห่วยแตกกับผมจริงๆ คนอื่นเป็นกันมั้ย 
            แต่ผมเป็นนะ  
        </p>
        <div class="row">
            <div class="col-lg-6">
               <img class="responsive pt-4" 
               src="https://i.ibb.co/vYt7cn2/IMG-20210517-085223.jpg" 
               alt="หมอยังไม่พร้อมปีนี้">
            </div>
            <div class="col-lg-6">
               <img class="responsive pt-4" 
               src="https://i.ibb.co/TgVgwc1/IMG-20210517-085356.jpg" 
               alt="ปีหน้าหมอยังไม่พร้อม">
            </div>
        </div>
        <p class="pt-2 mb-2">
            หรือว่ามือถือผมมันเป็นมือถือจีนกระจอกๆ ราคา 5 พัน แอพมันรังเกียจ 
            ต้องใช้ไอโฟนเท่านั้น ก็ถ้ามันเป็นแบบนั้น ผมก็ต้องขอโทษครับ ผมไม่ใช้ไอโฟนครับ 
            ต่อให้แจกฟรีผมก็ไม่เอา คือผมมันพวกกระจอกที่ไม่ถูกกับของแพง เพราะไม่มีปัญญาซื้อ
        </p>
    </div>
</div>
',                                          
'1',                        
'2021-05-17 10:22:05',                
'2021-05-17 10:23:01'                 
);                                          



/* วิธีกำจัดแมงหวี่จากเวปที่ไร้ผล 17 May 2021 */
INSERT INTO `whatnews` (`id`,`user_id`,`whatnews_title`,`whatnews_body`,
`is_public`,`created_at`,`updated_at`) VALUES (NULL,
'1',                            
'วิธีไล่ หรือกำจัดแมงหวี่ จากเวปต่างๆ ที่ไม่ได้เรื่อง',                             
'
<!-- ========== วิธีไล่แมลงจากเวปที่ไร้ผล START ===== -->
<div class="row">

    <div class="col-lg-12">
        <p class="pt-2 mb-4">
            หน้าร้อนทีไรมันต้องมากันเป็นขบวนทุกวันเลยสิไอ้แมลงน่ารำคาญพวกนี้ "แมงหวี่" 
            รำคาญชิบหายจะนอนก็ไม่ได้ มันตอมตา มันเข้าหน้า เข้าหู ทำยังไงล่ะทีนี้ ลองไปค้นๆ 
            จากเวปไซต์ต่างๆ ดู (แค่พิมพ์ว่า วิธีกำจัดแมงหวี่ขึ้นมาเยอะแยะ) ลองเปิดขึ้นมาดูวิธีที่เค้า 
            แนะนำลองดูสักสองสามเวปไซต์ หรือลองเปิดขึ้นมาดูทุกๆ เวปไซต์ 
            จะเห็นได้ว่ามันเขียนแบบเดียวกันแทบทั้งหมดเลย (สงสัยคงจะก๊อปมาจากที่เดียวกัน ก็ไม่ได้
            ว่าอะไรรู้ๆ กัน) แต่ที่คาใจก็คือ ที่เอามาโพสๆ กันน่ะเคยได้ลองทำกันบ้างหรือเปล่า? 
            หรือแค่นั่งก๊อปบทความไร้คุณภาพเอามาโพสไปวันๆ เห็นแล้วสมเพช 
            ทำผมหมดตังไปเป็น 100 บาทเพราะทดลองวิธีการพวกนี้  
        </p>
    </div>
    <div class="col-lg-12">
        <img src="https://i.ibb.co/VQ1hNR6/2021-05-17-insect-non-sence.png" 
        title="วิธีการกำจัดแมงหวี่ที่ไร้ผล " alt="วิธีกำจัดแมงหวี่ที่ไร้ผล" class="responsive">
        <p class="pt-2 text-center">
            วิธีการกำจัดแมงหวี่ที่ไร้ผล
        </p>
    </div>
    <div class="col-lg-12">
        <p class="pt-4 mb-4">
            วิธีกำจัดแมงหวี่ของเค้า ตามเวป ไม่บอกว่าเวปไหน ไปเปิดดูเอง :
        </p>
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <th>วิธีการ</th>
                    <th>ทดลองแล้ว </th>
                    <th>ได้ผล? </th>
                </thead>
                <tbody>
                    <tr>
                        <td>
                            เทียนสมุนไพร
                        </td>
                        <td>
                            <span class="alert alert-warning">
                                ลองแล้ว
                            </span>
                        </td>
                        <td>
                            <span class="alert alert-danger">
                                ไม่ได้ผล
                            </span>
                        </td>
                    </tr>

                    <tr>
                        <td>
                            ดอกดาวเรือง
                        </td>
                        <td>
                            <span class="alert alert-warning">
                                ลองแล้ว
                            </span>
                        </td>
                        <td>
                            <span class="alert alert-danger">
                                ไม่ได้ผล
                            </span>
                        </td>
                    </tr>

                    <tr>
                        <td>
                            เชือกชุบน้ำมัน
                        </td>
                        <td>
                            <span class="alert alert-warning">
                                ลองแล้ว
                            </span>
                        </td>
                        <td>
                            <span class="alert alert-danger">
                                ไม่ได้ผล
                            </span>
                        </td>
                    </tr>

                    <tr>
                        <td>
                            สเปรย์ตะไคร้
                        </td>
                        <td>
                            <span class="alert alert-warning">
                                ลองแล้ว
                            </span>
                        </td>
                        <td>
                            <span class="alert alert-danger">
                                ไม่ได้ผล
                            </span>
                        </td>
                    </tr>


                </tbody>
            </table>
        </div>
        <p class="pt-4 mb-4">
            วิธีเดียวที่ผมทำแล้วมันได้ผลคือ เอาน้ำสบู่ใส่กระป๋องเสปรย์(กระป๋องน้ำยารีดผ้า 
            หรือกระป๋องน้ำยาเช็ดกระจก) แล้วสละเวลาวันละ 3-5 ชั่วโมงถ้ามันเยอะมากๆ 
            เหมือนกรณีของผม ผมทำแบบนี้ติดต่อกันสี่วัน โดยการออกไปนั่งฉีด 
            ฉีดให้โดนตัวแมงหวี่ (เพราะว่าไม่มีปัญญาหารังของมันจริงๆ) น้ำสบู่หรือน้ำผสมน้ำยาล้างจาน 
            ถ้าไปโดนปีกมัน มันก็จะบินไม่ได้ตกลงไปตายเกลื่อน จะเห็นได้ว่าจากที่นั่งข้างนอกไม่ได้ 
            แมงหวี่มันยกโขยงมากันเป็นพายุ มาตอมตา ตอมหู จนไม่สามารถจะทำอะไรได้เลย(
            เพราะว่ามันรำคาญ) ตอนนี้มาทีไม่เกินสิบตัว และล่าสุดวันนี้ (17-05-2564) ออกมานั่ง
            เป็นเวลา 10 นาที ไม่โผล่มาให้ฉีดเลยสักตัว แปลกดีนะ
        </p>
        <img class="responsive" 
        src="https://i.ibb.co/dBsQtxz/IMG-20210517-075915.jpg" 
        alt="วิธีของผมมันได้ผลแบบ 100%">
    </div>
</div>
<!-- ========== วิธีไล่แมลงจากเวปที่ไร้ผล END ===== -->
',                                          
'1',                        
'2021-05-17 07:22:05',                
