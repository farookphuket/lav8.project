/* update composer */
INSERT INTO `whatnews` (`id`,`user_id`,`whatnews_title`,`whatnews_body`,
`is_public`,`created_at`,`updated_at`) VALUES (NULL,
'1',                            
'I just update my composer on ubuntu box',                             
'
<div class="row">
    <div class="col-lg-4">

    </div>
    <div class="col-lg-12">
        <p>
            <b>Hi there</b> I just update composer on my Ubuntu box today(23 
            Apr 2021) after I never boot up for a long long time.
        </p>

        <p class="pt-4 mb-2">
before update composer will be look like this when you run ''composer -v''
        </p>
        <img src="https://i.ibb.co/nkZmFHt/2021-04-23-composer-need-update.png" 
        alt="the photo text if you have" class="responsive mb-4">
        <p class="pt-2">to actully update composer from version x1 to version 
        x2 is quite simple as just one single command</p>
        <textarea class="form-control">sudo composer self-update</textarea>

        <p class="pt-4">after run the above command now when you run 
        ''composer -v'' you should see your composer version has changed!</p>
        <img src="https://i.ibb.co/0czpxYX/2021-04-23-composer-has-update.png" 
        class="responsive">

    </div>
</div>
',                                          
'1',                        
'2021-04-23 13:22:45',                
'2021-04-23 13:23:45'                 
);                                          




/* review nissn kick e-power 06-04-2021 */
INSERT INTO `whatnews` (`id`,`user_id`,`whatnews_title`,`whatnews_body`,
`is_public`,`created_at`,`updated_at`) VALUES (NULL,
'1',                            
'ลองขับ Nissan Kicks e-Power ไม่ประหยัดนะ แต่ขับโคตรมัน One Pedal ดีงาม 
ออปชั่นพอใช้ ค่าตัว 1.049 ล้าน',                             
'
<p>I love the ev car this is the review (in Thai) of nissan kick ev year 2021</p>

<div class="video-container">
     <iframe width="560" height="315" src="https://www.youtube.com/embed/JMd42sfh_kU" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
</div>
<p class="text-center pt-2 mb-4">ลองขับ Nissan Kicks e-Power ไม่ประหยัดนะ 
แต่ขับโคตรมัน One Pedal ดีงาม ออปชั่นพอใช้ ค่าตัว 1.049 ล้าน</p>
<p class="pt-2 mb-4 text-center">
รีวิว นิสสัน คิก อีพาวเวอร์ ขึ้นเขาเมืองระนอง
</p>
<div class="video-container">
<iframe width="560" height="315" src="https://www.youtube.com/embed/EjnqZtPyQks" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
</div>
<p class="pt-2 ">
autolifethailand.tv พาแฟนๆ มาลองขับ Nissan Kicks รถSUV เทคโนโลยี e-Power จาก Nissan ที่ขับเคลื่อนด้วยพลังงานไฟฟ้า ซึ่งถูกผลิตขึ้นมาจากเครื่องยนต์เบนซินขนาด 1.2 ลิตร ส่งผลให้ Nissan Kicks มีพละกำลัง 129 แรงม้า และแรงบิดสูงสุด 260 นิวตันเมตร
</p>
<p>
จุดเด่นของ Nissan Kicks คือเรื่องของเทคโนโลยี e-Power ที่ทำให้รถคันนี้มีลักษณะนิสัยในการขับเหมือนกับนถยนต์ไฟฟ้า (EV) โดยเฉพาะในเรื่องของอัตราเร่ง ที่คุณไม่สามารถหาได้ในรถที่ใช้เทคโนโลยีเครื่องยนต์ปกติ 
</p>
',                                          
'1',                        
'2021-04-06 09:19:45',                
'2021-04-06 09:19:45'                 
);                                          









/* ข่าวโควิด ในเมืองไทย on 2021-04-08 */
INSERT INTO `whatnews` (`id`,`user_id`,`whatnews_title`,`whatnews_body`,
`is_public`,`created_at`,`updated_at`) VALUES (NULL,
'1',                            
'ข่าวโควิดในเมืองไทย on 2021-04-08',                             
'
<p>
<b>โควิด19 </b> ในเมืองไทยแม้ว่าไม่ได้มากมายหากเทียบกับประเทศอื่นๆ ในโลก แต่ก็ยังเป็นเรื่องที่น่า 
กังวลอยู่มากหากดูจากข่าวในทีวีทุกๆ วัน วันนี้(08-04-2021) ก่อนวันสงกรานต์ ซึ่งแน่นอนแล้วว่าวันสงกรานต์ 
ในปีนี้(2564) ก็คงต้องหยุดกิจกรรมเสี่ยงทั้งหลายเพื่อคนไทยทุกๆ คน หากว่าทุกๆ คนร่วมมือกัน เราจะสามารถ
ข้ามพ้นวิกฤตินี้ไปด้วยกันได้ในเร็ววันนี้ ภาวนาให้คนไทยและผู้คนทุกๆ ในโลกนี้
</p>
<div class="video-container">
<iframe width="560" height="315" src="https://www.youtube.com/embed/DaS-JgrcGUU" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
</div>
<p class="pt-2 mb-4 text-center">
วิดิโอของวันที่ 7-04-64 นะครับผมยังหาวิดิโอของวันที่ 8 ไม่ได้เค้ายังไม่ประกาศ
</p>
<p class="pt-4 mb-2">
ข่าวจากรายการ อรุณสวัสดิ์ ฟ้าวันใหม่ ก๊อปปี้มาจากยูทูป 
</p>
<div class="video-container">
<iframe width="560" height="315" src="https://www.youtube.com/embed/1RY1TRgncrA" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
</div>
<p class="pt-2 mb-4 text-center">
จากรายการ อรุณสวัสดิ์ ฟ้าวันใหม่  08-04-64 ทาง youtube 
</p>
',                                          
'1',                        
'2021-04-08 11:56:45',                
'2021-04-08 11:56:45'                 
);                                          









/* my bash script setup i3wm for manjaro */
INSERT INTO `whatnews` (`id`,`user_id`,`whatnews_title`,`whatnews_body`,
`is_public`,`created_at`,`updated_at`) VALUES (NULL,
'1',                            

'my bash script for setup i3wm in manjaro',                             
'
<p class="mb-4">
    <b>I''ve</b> been using Manjaro for a 1 year and I really love this distro 
just because how simplicity is it and manjaro KDE is my belove favour after 
a while when I got use to the KDE I also learn to use another window manager 
like i3wm as it is a very easy one for the beginner like me
</p>

<p>but to setup i3wm in the way that I want to use and to set the key binding 
is still something that I have to do over and over again in every single time 
that I have to re-install my system in case I have done any thing stupid to 
my system and the whole system has totally crashed </p>


<p>so to prevent from all of the reparative step to get all the way throught 
I just learn how to make an auto script to do thing for me and put all of 
those script and the config file to github so this way I can re-use them 
and I can share in between my computer ,laptop also to share with another 
people too </p>
<p class="pt-2 mb-2">
please feel free to have a look or download my dot file 
<a href="https://github.com/farookphuket/desktop-i3.git" 
class="btn btn-outline-primary btn-sm" target="_blank">here</a>
</p>
<div class="form-group">
<textarea 
class="form-control mb-4" >https://github.com/farookphuket/desktop-i3.git</textarea>
</div>

<div class="video-container">
<iframe width="560" height="315" src="https://www.youtube.com/embed/q3Sanjl93dQ" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
</div>
',                                          
'1',                        
'2021-04-02 08:05:45',                
'2021-04-02 08:06:45'                 
);                                          





