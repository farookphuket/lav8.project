/* cmus 27 jan 2021 */


INSERT INTO "whatnews" ("id","user_id","whatnews_title","whatnews_body","is_public","created_at","updated_at") VALUES (NULL,
'1',
'cmus is my best music player from now on ',
'
<p>
today (25 jan 2021) I just re-install manjaro on my computer just right after
the manjaro xfce which I try to config to use i3wm and it is end up with the system
is crash all the time I don''t know what I did wrong with it the cpu fan spin like
crazy so I have to re-install the new one this time I use manjaro-i3 20.2.2 so 
thing is come out of the box and it is working very very well like I ever expected
it to be 

</p>

<p>
once the install and update has complete I just try to find which music player
is can be replace my ''rhythmbox'' my belove music player from all time but I 
cannot use it now with th current version of rhythmbox I just don''t like the 
lack of the interface when I change the song it is appear as it is crash(but it wasn''t)
so that how the story come why I have to leave rhythmbox as I stil love it
for me there is none music player out there can replace rhythmbox I did try many 
  many of them but no no 
</p>

<p> 
<b>so cmus</b> I know nothing about it just see the first time from bmenu
it has "M" as a music player so I just enter to it at the very first 15 minute
was a big big confuse to me "how to I add music?" ,"how do I do?..." 
and I even have the problem that cmus only run once and it throw error said 
"error opening false internal error" so what I do to solved the problem was 
one command "rm -rf .config/cmus/autosave" just after I read from "https://bbs.archlinux.org/viewtopic.php?id=223095"
now thing was completely working good I love you manjaro-i3+cmus
</p>


<img src="https://i.ibb.co/dQHLJR3/2021-01-27-cmus-best-music-player.png" class="responsive">



',
'1',datetime('now','localtime'),datetime('now','localtime'));
