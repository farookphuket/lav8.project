/* how do I install puddletag-snap on 26 Jan 2021 */

INSERT INTO "whatnews" ("id","user_id","whatnews_title","whatnews_body",
"is_public","created_at","updated_at") VALUES (NULL,
'1',
'How do I install puddletag on manjaro 20.2.2 26-Jan-2021',
'
<p>
<b>Puddletag</b> is the program to edit the tag file I use it mosly

when I want to edit the mp3 file info such as to Add picture of the artist
to that song Puddletag is not in pamac or pacman repo so tto install it
I found it from here : "<a href="https://snapcraft.io/install/puddletag-snap/manjaro" target="blank"
>https://snapcraft.io/install/puddletag-snap/manjaro</a>"
</p>
<img
src="https://res.cloudinary.com/canonical/image/fetch/f_auto,q_auto,fl_sanitize,w_819,h_512/https://dashboard.snapcraft.io/site_media/appmedia/2020/12/Bildschirmfoto_von_2020-12-06_17-02-23.png" class="responsive">
<p>
to install run the command :sudo snap install puddletag-snap make sure
you have snap install mostly if you use manjaro it is already installed so
that you ready to go.
</p>


',
'1',
'2021-02-09 07:45:20',
'2021-02-09 07:45:20'
);


