



/* remove node_modules folder due to the file size matter */


INSERT INTO "whatnews" ("id","user_id","whatnews_title","whatnews_body","is_public","created_at","updated_at") VALUES (NULL,
'1',
'I just delete the node_modules folder',
'
<p>due to the file size matter and the fact that we have nothing to do with node_modules folder and it''s content so I just delete and set the .gitignore for nodee_modules to just ignore it from looking and sync with the project code base on github now for new git pull please go to the root of your project foder then run "npm install" the node_modules folder will be back for you to start develop with any of the new vue components</p>

',
'1','2021-01-31 16:45:15','2021-01-31 16:45:15' );


/* how can I add datetime to .sqlite */

INSERT INTO "whatnews" ("id","user_id","whatnews_title","whatnews_body","is_public","created_at","updated_at") VALUES (NULL,
'1',
'How can I add datetime to .sqlite for auto data',
'

Hi there today is 25 Jan 2021 I don''t know how can I add automatic datetime 
to .sqlite file so I got it from here "https://www.sqlitetutorial.net/sqlite-date/"
and now I want to escaping the single quote which is not accept by sql what I do is 
I put two single quote('') to replace and it is working as I expected I got it from
"https://stackoverflow.com/questions/603572/escape-single-quote-character-for-use-in-an-sqlite-query"
now what else trick I learn today in (25-Jan-2021)

',
'1',datetime('now','localtime'),datetime('now','localtime'));



/* how do I install puddletag-snap on 26 Jan 2021 */

INSERT INTO "whatnews" ("id","user_id","whatnews_title","whatnews_body","is_public","created_at","updated_at") VALUES (NULL,
'1',
'How do I install puddletag on manjaro 20.2.2 26-Jan-2021',
'
<p>
<b>Puddletag</b> is the program to edit the tag file I use it mosly 

when I want to edit the mp3 file info such as to Add picture of the artist
to that song Puddletag is not in pamac or pacman repo so tto install it 
I found it from here : "<a href="https://snapcraft.io/install/puddletag-snap/manjaro" target="blank" 
>https://snapcraft.io/install/puddletag-snap/manjaro</a>"
</p>
<img src="https://res.cloudinary.com/canonical/image/fetch/f_auto,q_auto,fl_sanitize,w_819,h_512/https://dashboard.snapcraft.io/site_media/appmedia/2020/12/Bildschirmfoto_von_2020-12-06_17-02-23.png" class="responsive">
<p>
to install run the command :sudo snap install puddletag-snap make sure you have 
snap install mostly if you use manjaro it is already installed so that you
ready to go.
</p>


',
'1',datetime('now','localtime'),datetime('now','localtime'));


