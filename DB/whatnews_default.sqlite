/*
Error: Cannot find module ''semver''
*/
INSERT INTO "whatnews" ("id","user_id","whatnews_title","whatnews_body",
"is_public","created_at","updated_at") VALUES (NULL,
'1',                            
'Error cannot find  module semver 09-03-2021',                             
'
<p>
    <b>today 09-03-2021</b> I just ran the command to update my system 
    "sudo pacman -Syu " and once it almost done it has say something about 
    nodejs so to solved this I just remove the dir "/usr/lib/node_modules/" 
    when the update has done so I reboot then back to my project and I run 
    "npm run watch" so the error has now show "Error cannot find module 
    semver" and cannot run the command I got this problem fixed from 
    <a href="https://stackoverflow.com/questions/48229026/npm-cannot-find-module-node-gyp-bin-node-gyp" class="btn btn-outline-info" 
    target="_blank">stackoverflow</a> the command to run is 
</p>
<textarea  class="form-control">sudo pacman -Sy node-gyp 
npm update
</textarea>
<p>
this is what work for me 
</p>
',                                          
'1',                        
'2021-03-09 22:15:45',                
'2021-03-09 22:15:45'                 
);                                          





INSERT INTO "whatnews" ("id","user_id","whatnews_title","whatnews_body",
"is_public","created_at","updated_at") VALUES (NULL,
'1',                            
'Why I don''t do Window - Joe Collins',                             
'
<p>
<b>I''ve copy</b> Joe Collins''s video from youtube 
</p>
<p class="pt-2 mb-4">
    <b>October 1998</b> is the first time in my life that I''ve ever touch 
    the computer it was <a href="https://en.wikipedia.org/wiki/Windows_98" 
    class="btn btn-outline-info btn-sm" target="_blank">window 98 (wiki)</a>
    I still remember deep in my mind
    <em>how was the feeling like</em>?

</p>
<p>
    There are so many people do not like Window 98 because it''s crash very 
    often but to me at that time I know nothing about computer (even
    now I still knowing nothing yeah not much) so I just get a chance to learn 
    thing about computer since then and soon enough I am in the group
    of people who''ve said "yes ,window 98 is crash very often" moving on to 
    two years later

</p>
<div class="video-container">
    <iframe width="560" height="315" 
    src="https://www.youtube.com/embed/CrvKyR9DGUY" frameborder="0" 
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; 
    gyroscope; picture-in-picture" allowfullscreen=""><br></iframe>
    <br>
</div>

<p class="pt-2 text-center">
    Why I don''t do window - by Joe Collin
</p>
<p>
Thanks to window ,Thanks to all of the programmer or creator in the world to 
make thing for another people to use.
</p>

',                                          
'1',                        
'2021-03-06 15:15:45',                
'2021-03-06 15:18:45'                 
);                                          






INSERT INTO "whatnews" ("id","user_id","whatnews_title","whatnews_body",
"is_public","created_at","updated_at") VALUES (NULL,
'1',                            
'Stop Hating On Linux Mint! - Joe Collins',                             
'
<p class="mb-4">
 <b>All</b> linux (Linux mint included) are greate and I will never say or 
 do any thing to make another people to hate any thing that any other has 
created for another to use doesn''t matter if it free (Like linux) or paid 
(like Mac and Window) 
</p>
<p>
    <b>Me</b> personally I am using Manjaro 20.02 now(2021-Feb-21) (I''m 
start using manjaro since year 2020 and fall in love with this distro) but 
I am get to know linux by using Ubuntu ,Ubuntu mate, Linux mint,Mx linux 
,Debian ,Pop os ...and so on I can''t remember but the ony thing I know was 
I like all of them , none of them is useless no no.
</p>
<p class="pt-2 mb-4">
I like what''s Joe Collins has said in his video to reply to the other people 
who maybe do not like or using Linux mint.
</p>

<div class="video-container">
<iframe width="560" height="315" 
src="https://www.youtube.com/embed/szDHAeaqJD8" frameborder="0" 
allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; 
picture-in-picture" allowfullscreen></iframe>
</div>
<p class="pt-4 mb-4">
    well, to me I am a linux user since year 2007 start with Ubuntu 7.04 
and since I start using linux I am never return back to use window again 
but it''s not because I hate window no no I hate nothing form any other people
has create for the other people to use whether it''s paid or free 
you have your like or not like it but you cannot point your finger to force 
any other people to like what you''re like that''s my opinion
</p>
',                                          
'1',                        
'2021-02-21 10:05:45',                
'2021-02-21 10:06:45'                 
);                                          



