/* just install neovim on laptop 19 Feb 2021 */
INSERT INTO "whatnews" ("id","user_id","whatnews_title","whatnews_body",
"is_public","created_at","updated_at") VALUES (NULL,
'1',                            
'Wow! I just fall in love with neovim already', /* title */                            
'
<div class="row">
    <div class="col-lg-4">
        <img class="responsive" 
        src="https://i.ibb.co/3mh6Qmv/2021-02-19-neovim-wiki.png" 
        alt="neovim from wiki pedia">
        <p class="text-center">
            neovim from wiki pedia
        </p>

    </div>
    <div class="col-lg-8">
        <p>
            <b>
            <a href="https://en.wikipedia.org/wiki/Vim_(text_editor)" 
            class="btn btn-outline-info" target="_blank">
            Neovim </a></b> 
            Yeah! ,I know it was there for a long time (since 2014) but to me 
            Hmm....I just have tried today baby so yes it''s definitely new  
            for me so to say.
        </p>
        <p class="pt-2 mb-2">
            I''ve just copy the config from 
            <a href="https://www.chrisatmachine.com/Neovim/02-vim-general-settings/" target="_blank" class="btn btn-outline-info">Chris@Machine</a> on the 
            18-Feb-2021 and I just edit something in my own way so there will 
            be some different key binding in my config just to make it suit my 
            need. 
        </p>
        <p class="pt-2 mb-2">
            to copy my config fire-up terminal then copy the code or go to 
            <a href="https://github.com/farookphuket/far_vimrc" 
            class="btn btn-outline-info" target="_blank">far_vimrc</a> just 
            to read the "README" first 
        </p>
        <div class="form-group">
            <label for="">Copy the below code</label>
            <input class="form-control" type="text" 
            value="git clone https://github.com/farookphuket/far_vimrc.git">
        </div>
        <p class="pt-2 mb-2">
            you will get the folder name "far_vimrc" then just copy the folder 
            "neovim" to paste into "~/.config" folder now you will have my 
            neovim config 
        </p>

    </div>
</div>
',  /*  Body (well it''s an excerpt ) */
'1',   /* publish = 1 not publish = 0 */ 
'2021-02-19 04:05:45',                
'2021-02-19 04:06:45'                 
);                                          





