/* How much change of you?*/
INSERT INTO `whatnews` (`id`,`user_id`,`whatnews_title`,`whatnews_body`,
`is_public`,`created_at`,`updated_at`) VALUES (NULL,
'1',                            
'
คุณเปลี่ยนไปแค่ไหน? ผมเหรอ อืม.....เยอะมาก

',                             
'
<div class="row">
    <div class="col-lg-12">
        <p>
            how much change that happen to you from the pass up until now
            ปีๆ หนึ่งไหงมันช่างไวไปเสียนี่ รู้ตัวอีกทีก็ เห้อ 40 กว่าแล้วนะ ยังไม่มีอะไรเลย 💔
        </p>
    </div>
    <div class="col-md-4">
        <img src="https://i.ibb.co/HBptJC3/farook-year2006.jpg" class="responsive">
        <p class="text-center pt-2">year 2006</p>
    </div>

    <div class="col-md-4">
        <img src="https://i.ibb.co/PcS56LN/farook-year2007.jpg" class="responsive">
        <p class="text-center pt-2">year 2007</p>
    </div>

    <div class="col-md-4">
        <img src="https://i.ibb.co/BzZ5HNL/farook-year2007-2.jpg" class="responsive">
        <p class="text-center pt-2">year 2007_2</p>
    </div>

    <div class="col-md-4">
        <img src="https://i.ibb.co/18xQmdJ/farook-year2009.jpg" class="responsive">
        <p class="text-center pt-2">year 2009</p>
    </div>

    <div class="col-md-4">
        <img src="https://i.ibb.co/zxBw2yY/farook-year2011.jpg" class="responsive">
        <p class="text-center pt-2">year 2011</p>
    </div>



    <div class="col-md-4">
        <img src="https://i.ibb.co/GVgKNzX/farook-year2021.jpg" class="responsive">
        <p class="text-center pt-2">
            2021 ปีนี้ โครตแก่
        </p>
    </div>

    <div class="col-lg-12">
        <p>
            this is what I took with friends
        </p>

        <div class="row">
            <div class="col-lg-3">
                <img src="https://i.ibb.co/YbP2X8M/farook-and-friends2006.jpg" class="responsive">
                <p class="text-center pt-2">
                    ถ่ายกับพี่บิลลี่ พี่ชอร์ ตอนไปแข่งพายเรือ
                </p>
            </div>
            <div class="col-lg-3">

                <img src="https://i.ibb.co/rGq2jxF/farook-and-friends2006-2.jpg" class="responsive">
                <p class="text-center pt-2">
                    ถ่ายกับพี่บิลลี่ พี่ชอร์ ตอนไปแข่งพายเรือ
                </p>
            </div>

        </div>
        <p class="pt-6 mb-4">
            อันนี้ถ่ายกับ อิบรอน ลูกชายคนโต</p>
        <div class="col-md-6">
            <img src="https://i.ibb.co/tqSR0zM/20150508-farook-and-son.jpg" class="responsive">
            <p class="pt-2 text-center">
                ลูกชายโตเป็นหนุ่ม ส่วนพ่อ....เห้อ....
            </p>
        </div>

    </div>

</div>

',                                          
'1',                        
'2021-06-08 21:20:05',                
'2021-06-08 21:20:10'                 
);                                          




