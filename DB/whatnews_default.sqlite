/* ข่าวเกี่ยวกับ โควิด from youtube */
INSERT INTO "whatnews" ("id","user_id","whatnews_title","whatnews_body",
"is_public","created_at","updated_at") VALUES (NULL,
'1',
'The covid 19 news from youtube 15 Feb 2021',
'
<p>
<b>Covid 19</b> is still the most problem in the world by now 
ไปก๊อปข่าวนี้มาจาก ยูทูป เช้านี้เอง เรื่องเศรฐกิจว่าจะดีขึ้นเหรอ อืม ตอนนี้คงยาก ไอ้เรื่องธุรกิจท่องเที่ยว
ที่ต้องพึ่งชาวต่างชาติ ตอนนี้ก็ตายทุกราย หาอย่างอื่นทำให้ได้ ถ้าหาไม่ได้ก็อดตายนี่คือกฎของธรรมชาติ

</p>

<div class="video-container">
<iframe width="560" height="315" src="https://www.youtube.com/embed/gL5Ban8ee_g" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
</div>
<p class="text-center mb-4 pt-2">
ข่าวโควิดในเมืองไทย 15-Feb-2021
</p>

',
'1','2021-02-15 11:02:22','2021-02-15 11:03:10');





/* ข่าวกัญชาจากทาง youtube 12 Feb 2021 */
INSERT INTO "whatnews" ("id","user_id","whatnews_title","whatnews_body",
"is_public","created_at","updated_at") VALUES (NULL,
'1',
'เอกชนสู้ศึกชิงตลาด "กัญชง-กัญชา" I BUSINESS WATCH I 11-02-2021',
'
<p class="mb-4">
<b>เหล้า เบียร์ </b> กินแล้วเมา สร้างปัญหา(คนที่ไม่ได้สร้างปัญหาก็อย่าเดือดร้อนนะ)
ยกพวกตีกัน ทะเลาะกัน ขับรถชน ข่มขืน เพราะว่าคนเมาเหล้ามันขาดสติ (จริงๆ ไม่น่าจะโทษเหล้านะ
คนมันเหี้ย ไม่ต้องแดกอะไรเข้าไป ก็เหี้ย) แต่ปัญหาเหล่านั้นส่วนมากก็จะมาจาก เมาแล้วขาดสติก่อนทั้งนั้น

</p>
<p>
คนเสพ
<b>
 กัญชา
</b> จะต่างจากคนกินเหล้า เพราะคนเมากัญชาจะขี้กลัว ไอ้เรื่องยกพวกตีใครคงหมดสิทธิ์ ถ้าคนเมากัญชา
ขับรถชนคนเมากัญชา เคลียร์กันได้ด้วยของหวานถ้วยเดียว จากนั้นก็ต่างคนต่างไป หัวเราะร่าเริง
ไม่มีการยิงกันแน่นอน ได้เห็นข่าวนี้แล้วชอบ ก็ได้แต่หวังว่ามันจะถูกกฎหมาย ทำไมกัญชาผิดกฎหมาย
เพราะกัญชา ไม่มีฉลากว่า "เสียภาษีแล้ว" ยังไงล่ะ

</p>
<p class="pt-2 mb-4">
จะให้กัญชาสามารถปลูกได้ทุกๆ บ้าน ในตอนนี้น่าจะยังคงเป็นเรื่องที่ห่างไกล เพราะว่ามันจะทำให้ "นายทุน"
เสียผลประโยชน์ เรื่องนี้เป็นเรื่องที่ยอมไม่ได้ ประชาชนต้อง "รอไปก่อน" ถ้านายทุนยังไม่ได้ประโยชน์
ประชาชนก็ตีหม้อประท้วงไปเหอะ แต่ใครจะเหลียวแล
</p>
<div class="video-container">
    <iframe width="560" height="315"
    src="https://www.youtube.com/embed/BWwm2wk1Kc8"
    frameborder="0" allow="accelerometer; autoplay; clipboard-write;
    encrypted-media;
    gyroscope; picture-in-picture" allowfullscreen></iframe>
</div>

<p class="pt-4">
    ไม่ได้จะเอาไว้เสพหรอกนะ แต่จะปลูกขาย
</p>
',
'1','2021-02-12 10:43:45','2021-02-12 10:44:45');


/*  number 6 on date 9 Feb 2021 upgrade system to using php 8 */

INSERT INTO "whatnews" ("id","user_id","whatnews_title","whatnews_body",
"is_public","created_at","updated_at") VALUES (NULL,
'1',
'last upgrade system from php 7 to php8 on 9 Feb 2021',
'
<p>
<b>Hi there</b> today 9 Feb 2021 I just update the system the size of update
is 1.8 GB but after update my website project is not working the problem is
apache not start because it''s cannot find php 7(as it''s has upgrade to php8
now) so the httpd.conf file has to be edit
<span class="badge badge-info">
"sudo vim /etc/httpd/conf/httpd.conf "
</span>
the full article is will be found
<a class="btn btn-outline-primary"
href="https://wiki.archlinux.org/index.php/Apache_HTTP_Server" target="_blank">here</a>
</p>
<p class="pt-2 mb-2">
the image below is my recently use system before update
</p>
<p>
    <img src="https://i.ibb.co/vV9qPLR/2021-02-09-php7-4.png" class="responsive">

</p>
<p>
    <img src="https://i.ibb.co/JdpGfp7/2021-02-09-update-system.png" class="responsive">
</p>
<p>
    <img src="https://i.ibb.co/3pgZ7jw/2021-02-09-httpd-conf.png" class="responsive">
</p>
<p class="pt-4 mb-4">this is the edit file /etc/httpd/conf/httpd.conf</p>
<div class="line-numbers">
    <pre>
        <div class="code">

          <span>  LoadModule php_module modules/libphp.so</span>
          <span>  AddHandler php-script .php</span>
          <span>  Include conf/extra/php_module.conf</span>

        </div>
    </pre>
</div>
<p>
and now thing is back to work again
</p>


',
'1','2021-02-09 20:45:07','2021-02-09 20:47:08');




