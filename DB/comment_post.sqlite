 /* ================= backup `comments`  ======  2021-06-29 10:43:26 =============== */
INSERT INTO `comments`(`user_id`,`ip`,`comment_title`,
`comment_body`,`created_at`,`updated_at`) VALUES(
    '3','127.0.0.1','อาหารที่ชาวมุสลิมจะทานได้ในช่วงถือศีลอดคือ',
    '<p>ในการถือศีลอดจะทานอาหารหลัก ๆ 2 มื้อ คือ ซุโฮร์ (Suhoor) เป็นมื้อก่อนแสงอรุณ ถือเป็นมื้อแรกของวัน ทำให้ต้องหาอาหารที่มีโปรตีนสูงเพื่อให้อิ่มท้องนาน ๆ และอีกมื้อคือ อิฟตาร์ (Iftar) เป็นมื้ออาหารที่ทานหลังพระอาทิตย์ตก โดยอาหารที่นิยมทานเพื่อเติมโปรตีน เช่น มะตะบะเนื้อ ข้าวมันไก่ ข้าวหมกไก่ เป็นต้น นอกจากนี้ยังมีอินทผาลัม ผลไม้จากตะวันออกกลางที่หาทานได้ง่ายขึ้นเมื่อเข้าสู่เดือนรอมฎอน ตามประวัติศาสตร์ศาสนาอิสลาม อินทผาลัมเป็นผลไม้ที่ท่านนบีมูฮัมหมัดส่งเสริมให้ชาวมุสลิมทานคู่กับน้ำเปล่า โดยควรทานทั้งอินทผาลัมผลสด (ฤทธิ์เย็น) และอินทผาลัมผลแห้ง (ฤทธิ์ร้อน) เพื่อให้ร่างกายเกิดสมดุล นอกจากนี้แพทย์แผนปัจจุบันยังได้ศึกษาและระบุว่า อินทผาลัมเป็นผลไม้ที่มีคุณค่าทางโภชนาการสูงอีกด้วย</p>','2021-06-29 10:43:26',
    '2021-06-29 10:43:26');

