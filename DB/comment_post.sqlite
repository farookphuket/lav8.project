INSERT INTO `comments`(`user_id`,`ip`,`comment_title`,
`comment_body`,`created_at`,`updated_at`) VALUES(
    '3','127.0.0.1','ฟังนิยายเพชรพระอุมา ตอน มงกุฎไพร',
    '<p>เป็นการอัพเดทอีกครั้งเพื่อรวมคลิปเสียงไว้เป็นแค่ 4 คลิปเพื่อความสะดวกในการฟัง ท่านสามารถปิดหน้าจอมือถือได้โดยที่คลิปจะยังเล่นอยู่ หากต้องการหยุดให้กดปุ่มหยุดเอาไว้ แต่อย่าปิดหน้าเวปเพราะว่าหากเปิดขึ้นมาใหม่จะเป็นการเริ่มเล่นใหม่ทั้งหมด</p>','2021-06-29 11:02:00',
    '2021-06-29 11:02:00');

