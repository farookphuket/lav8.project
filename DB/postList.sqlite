/* my keyboard layout on manjaro i3 now is working */ 


INSERT INTO "posts" ("id","user_id","post_title","slug","post_excerpt",
"post_body","is_public","last_read_ip","last_read_date","read_count",
"created_at","updated_at") VALUES (NULL,
'1',/* user id */
'I am finally can get the language switcher to work in manjaro i3wm',/* title */
'i-am-finally-can-get-the-language-switcher-to-work-in-manjaro-i3wm', /* Slug */

'

<div class="row">
    <div class="col-lg-4">
        <img src="https://i.ibb.co/jDd1RWL/2021-01-27-keybord-layout.png" class="responsive">
        <p>
            I got my keyboard layout to show in i3wm now
        </p>
    </div>
    <div class="col-lg-8">
        <p>
            <b>
                My
            </b>
            keyboard layout never show up since I start to usin "I3WM" in manjaro
            and I cannot find any solution for that even tried so hard to search on the
            internet but no still luck so I just forgot about it for so long
        </p>
        <p class="pt-2 mb-4">
            <b>Since</b> a few days ago(it''s 25 of Jan 2021 if I''m not wrong
            my desktop computer which run manjaro 20.2 xfce was terriblly crash
            (well it is crash because I did a lot of a stupid thing with the system
            plus maybe I got so many error config and so many crash program install
            maybe that''s the reason) so I have to re-install the os again but this time
            I install manjaro-i3.

        </p>

    </div>
</div>

'
, /* excerpt */
'
<div class="container">
    <img src="https://i.ibb.co/Wyz585K/2021-01-27-locale-setting.png" class="responsive">
    <p>
        make sure that you have set the locale
    </p>
    <p>
        <b>
            when

        </b>
        come to start using manjaro with i3wm that I try to config it
        by search from the article on the internet even I can make it look very
        similar to what the other people show but I still got a problem as
        I have to respect that "we are on the difference machine" so things
        that work on another may not work on me and it''s seem to be so true!
        I can setup i3wm by copy someone else from the internet but I have a problem
        for one "No keyboard layout show" this is one of the thing that hard for
        me because I have to type in "Thai" so if I don''t know what is the current
        keyboard layout that I use now it''s mean that I will type in Thai
        then I have to delete which is wasted time for me as I cannot type
        without looking at the keyboard(I think they call touch-type) so
        every key stroke that I type I have to look before I can press
    </p>
    <p>
        back to "how can I get the keyboard layout to show?" I install
        the program call "xxkb" by run the command "<i>sudo pacman -S xxkb </i>"
        after the install I create the file in my home directory call ".xxkbrc"
        by run the command "<i>vim ~/.xxkbrc</i>" the paste the following code below
    </p>
    <div class="form-group">
        <label>Just copy and paste</label>
        <textarea class="form-control" rows="8">XXkb.image.path: /home/farook/.config/xxkb
  
  XXkb.group.base: 1
  XXkb.group.alt: 2
  
  
  XXkb.mainwindow.type: tray
  XXkb.mainwindow.enable: yes
  XXkb.mainwindow.appicon: yes
  XXkb.mainwindow.border.width: 1
  XXkb.mainwindow.label.enable: yes
  XXkb.mainwindow.label.background: black
  XXkb.mainwindow.label.foreground: white
  XXkb.mainwindow.label.font: SourceCodeVariable 14
  XXkb.mainwindow.border.color: white
  XXkb.mainwindow.geometry: 20x20+0+0
  XXkb.mainwindow.image.1: us.xpm
  XXkb.mainwindow.image.2: th.xpm
  XXkb.mainwindow.image.3:
  XXkb.mainwindow.image.4:
  XXkb.mainwindow._delete: no
  
  XXkb.button.enable: no
  
  XXkb.controls.focusout: no
  XXkb.controls.two_state: no
  XXkb.controls.add_when_start: yes
  XXkb.controls.add_when_create: yes
  XXkb.controls.add_when_change: no
        </textarea>
    </div>
    <p class="pt-4 mb-2">
        now create the folder in "~/.config" by run the command "<i>mkdir ~/.config/xxkb</i>"
        just incase in the future maybe we can find the .xmp file "th and us flag"
        so we will put in this folder
    </p>
    <p>
        now open the file ".xinitrc" we have to add xxkb to run when we login to i3
        by run the command "<i>vim ~/.xinirc</i> " then add "<em>xxkb &amp;</em>"
        just before the last line then you have to edit your i3 config file too
        now type "<i>vim ~/.config/i3/config</i> " then add the line
    </p>
<div class="line-numbers">
    <pre>            
        <code class="language-config">
                exec_always setxkbmap -model pc105 -layout "us,th" -option ''grp:alt_shift_toggle''
                exec_always --no-startup-id xxkb     
        </code>
    </pre>
</div>
    <p>
        this is all the step that I have done to make the keyboard status to show
        now I can click on the label or press "control+alt" key to toggle between
        Thai and English
    </p>
    <p>
        so if you like to try my method all of this is what I''ve done on both
        desktop and laptop and it''s work very well no doubt on my computer

    </p>
    <p>
        goodluck!
    </p>
</div>



',/* The post body */
'1','','2021-01-25','0','2021-01-27 14:35:35','2021-01-27 14:37:35' );
