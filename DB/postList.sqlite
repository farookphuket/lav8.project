INSERT INTO "posts" ("id","user_id","post_title","slug","post_excerpt","post_body","is_public","last_read_ip","last_read_date","read_count","created_at","updated_at") VALUES (NULL,
'1',
'beware simple thing is some time not simple',

'beware-simple-thing-is-some-time-not-simple',

'
<b>Some time</b> a simple thing is some thing that I just never thinking about 
like today(6 feb 2021) I spend the whole day try to figure out why the share 
hosting cannot send email from localhost it''s use to work very well with my 
simple code & config so why today is not why the share hosting block port 25 
the answer is really make me shock! 

',

'

<div class="container">
    <p class="mb-3">
    <b>it''s simply</b> just change the network connection and the code just 
come back to work as it use to 
    </p>
    <img src="https://i.ibb.co/F7pPrhN/2021-02-06-change-network.png" 
    class="responsive">

    <p class="pt-4">
        so when I switch the network connection the code is come back to work 
        again how crazy is that? I spend the whole day today try to thinking
        why? why the share host is not let me send email from the localhost 
        through it why my computer maybe block the 25 port why my code is not 
        working it is use to work before what I done wrong oh dear
    </p>
    <p>
        Any way it''s another day today in my coding experience that I can 
        solved the problem. 
    </p>


</div>





','1','','2021-01-25','0','2021-2-6 21:50:45','2021-2-6 21:55:45');


/* cmus  START 27 jan 2021 */


INSERT INTO "posts" ("id","user_id","post_title","slug","post_excerpt","post_body","is_public","last_read_ip","last_read_date","read_count","created_at","updated_at") VALUES (NULL,
'1',
'get to know and how to use cmus in my 15 minute',

'get-to-know-and-how-to-use-cmus-in-my-15-minute',

'

<div class="row">
    <div class="col-lg-4">
        <img src="https://i.ibb.co/svbfBpY/2021-01-27-cmus-best-music-player.png" class="responsive">
        <p>Cmus is great</p>
    </div>
    <div class="col-lg-8">

        <p>
            <b>Rhythmbox</b> is the best music player I ever have on my computer for all time since Aug 2007 when I first try to using
            "ubuntu 7.04" as my first time I ever install linux into my computer still remember how much I missing "window xp" but I have to
            get rid of window it''s not because window is bad or anything I love window I learn how to use computer from "window 98"
            that was the first time in mylife I ever touch the computer and I have learn a lot from window so thank you
            to window operating system
        </p>
        <p>
            <b>Cmus</b> is a very cool and will be my music player on 2021 and so on 
            it is very fast and feature rich and yes! it''s powerful
        </p>
    </div>
</div>


',

'


 <div class="container">
    <div>
        <img src="https://i.ibb.co/svbfBpY/2021-01-27-cmus-best-music-player.png" class="responsive">
        <p class="text-center">Cmus is lightweight and yes powerful</p>
    </div>

    <p class="pt-4 mb-2">
        cmus is a lightweight ncurses music player. It supports various output methods
        by using dynamically-loaded output plugins. cmus has configurable keybindings
        and can be controlled externally using cmus-remote if you are a vim fan
        you will falll in love to cmus completely in just a few moment when you know it
        but it''s will not be easy if this is your first touch
        so this post will be "how can i use cmus in the first 15 minute".

    </p>
    <h2 class="text-center">

        How to open cmus
    </h2>
    <p>
        at this point I assume that you have install it already
        cmus will be run in the command-line so fire up your command line program
        (I use terminal)
    </p>

    <div class="col-md-10">
        <label>just copy and paste</label>
        <input type="text" value="cmus" class="form-control">
    </div>

    <p class="pt-4 mb-4">the first run you will only see the blank screen like this </p>
    <img src="https://i.ibb.co/P9Phxq5/2021-01-27-cmus-blank.png" class="responsive">


    <h1 class="pt-4 text-center">
        How can I add song to the library
    </h1>
    <p>
        now you have number 1 to 7 press the number 5 you can use the aero key up and down
        or if you are vim fan just press "j" to go down "k" to go up you will see the
        hilight now just navigate to your music library in my case here is in the path
        "/run/media/farook/DATA2TB/ITuneCopy" you can see it is hilighted now
        so I just press "a" to add all my music in to the cmus list and you will the hilight
        will move to the lower line which mean that the music is added
    </p>
    <img src="https://i.ibb.co/dfVbmT3/2021-01-27-cmus-nav-to-music.png" class="responsive">

    <h2 class="pt-4 text-center">
        your music now is ready!
    </h2>
    <p>
        <span class="badge badge-warning">
            do you know?
        </span> that your music is ready for you now just press "2"
        to return to your music library now you will that I have "3131" file in here
        now all you have to do is move the pointer to the song that you want to listen
        then hit enter or "x" button then it will start to play to pause press "c"
        to stop press "v"
    </p>
    <img src="https://i.ibb.co/fdTTFvW/2021-01-27-cmus-list-view.png" class="responsive">

    <h2 class="pt-4">
        How can I create a new playlist?
    </h2>
    <p class="mb-4">
        press "3" follow by ":pl-create your-playlist-name" hit enter press "j"
        to move the cursor down to select the new playlist that we just created
        press "space" key now you will see the "*" sign is come to focus
    </p>
    <img src="https://i.ibb.co/8Bc7zHM/2021-01-28-cmus-new-playlist.png" class="responsive">
    <h2 class="pt-4">
        How can I add music into my playlist?
    </h2>
    <p class="mb-2">
        press "2" then move the cursor up or down by press "j" or "k" to select
        the music by press "space" to add the music to the playlist press "y"
        you can also press "e" to add the select song to be the next play too
        now to go back to the playlist press "3" you will see the select song in
        your the right panel of the playlist
    </p>
    <img src="https://i.ibb.co/5WymR2x/2021-01-28-cmus-select-song.png" class="responsive">
    <h2 class="pt-4 mb-2">
        But I have so many song! can I search to the specific song?
    </h2>
    <p class="mb-2">
        <span class="badge badge-success">
            yes!
        </span> you can search to the specific song by press "/"(slash sign) then
        type the word name hit enter to find the next song you can keep on press
        "n" until you find the specific song that you want to select the song press
        "space" to find another song just redo the process before or you can press
        "/" (slash sign) follow by the "aero" key up or down to see the search
        history one by one in each time you press the aero key

    </p>
    <h2 class="pt-4">
        How to manage song in my playlist?
    </h2>
    <p class="mb-2">
        to manage the song in the playlist
        press "TAB" you will see the cursor focus on the right panel press "j" or "k"
        to move cursor up or down if you listen to the music now the step below
        will not really disturb you much unless you press "enter" then the "current"
        hilight song will be play but your select song will still remain the same



    </p>
    <p>
        (
        <span class="badge badge-danger">
            Keep
        </span>
        <span class="badge badge-warning">
            in mind that your playlist not yet save now not yet!</span> )
    </p>
    <ol class="pt-4 mb-4">
        <li>
            1) to move 1 song up press "P" (upper case p)
        </li>
        <li>
            2) to move 1 song down press "p" (lower case p)
        </li>
        <li>
            3) Select or Not select by press "space bar" key
        </li>
        <li>
            4)
            you can select the song more than one by press "space" to move or if you want to move all select song up or down you have to move the cursor to the point
            that you want the select song to be then press "P" or "p"(upper case p
            to go up lower case p to place down) but the select song still selected
            how to un-select press ":unmark"(press "colon" type "unmark")
            hit enter the select will be gone
        </li>
        <li>
            to remove song from this playlist by move the cursor to the song then
            press "D"(upper case d) to remove the whole playlist press "TAB" follow
            by press "D"(upper case d) follow by "y" the hit "enter" all the playlist
            will be gone.
        </li>
    </ol>

    <img src="https://i.ibb.co/Wp2qpTx/2021-01-28-cmus-manage-song-in-playlist.png" class="responsive">
    <p class="pt-2">
        <strong>
            <span class="badge badge-warning">
                Keep in mind!
            </span>
        </strong> that your playlist is <span class="badge badge-danger">
            NOT
        </span> save now not yet until you press "<span class="badge badge-success">
            :save
        </span>" hit enter and if you do any change to your playlist you have to do "<span class="badge badge-success">
            :save
        </span>" in every time to keep change now at this point I assume that you have
        press "<span class="badge badge-success">:save</span>" so now we move on.

    </p>
    <h2 class="pt-4 mb-2 text-center">
        but where is my playlist file that I just create and save?
    </h2>
    <p>
        after you have type "<span class="badge badge-success">:save</span>" your
        playlist will be save to "<span class="badge badge-info">~/.config/cmus/playlists/playlist-file-name</span>"
    </p>
    <img src="https://i.ibb.co/V9fJ66k/2021-01-28-cmus-where-is-save-playlist.png" class="responsive">
</div>





','1','','2021-01-25','0',datetime('now','localtime'),datetime('now','localtime'));


/* End of cmus */









